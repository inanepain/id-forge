{
    "name": "inanepain/id-forge",
    "description": "A lightweight, versatile PHP library for generating and encoding unique identifiers. It supports base32, base58, base64, nanoid, snowflakeid, uuid, and ulid, providing fast, secure, and flexible solutions for ID generation and encoding in modern applications.",
    "type": "library",
    "license": "Unlicense",
    "homepage": "https://git.cathedral.co.za:3000/inanepain/id-forge",
    "readme": "README.adoc",
    "authors": [
        {
            "name": "Philip Michael Raab",
            "email": "philip@cathedral.co.za",
            "role": "Developer"
        }
    ],
    "support": {
        "email": "philip@cathedral.co.za",
        "issues": "https://git.cathedral.co.za:3000/inanepain"
    },
    "keywords": [
        "inanepain",
        "id-forge",
        "unique identifier",
        "id generation",
        "base32",
        "base58",
        "base64",
        "nanoid",
        "snowflakeid",
        "uuid",
        "ulid",
        "php",
        "encoding",
        "cryptography"
    ],
    "autoload": {
        "psr-4": {
            "Inane\\IdForge\\": "src/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "optimize-autoloader": true,
        "discard-changes": true,
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "require": {
        "php": ">=8.4",
        "inanepain/stdlib": ">=0.7.1 || dev-master || dev-develop"
    },
    "require-dev": {},
    "scripts": {
        "mk-doc-dir": [
            "mkdir -p doc/{changelog,readme}",
            "mkdir -p doc/changelog/release",
            "mkdir -p doc/readme/part",
            "touch doc/{changelog,readme}/index.adoc",
            "touch doc/changelog/release/0.0.0.adoc",
            "touch doc/readme/part/install.adoc"
        ],
        "build": [
            "echo build: all",
            "@build-changelog",
            "@build-readme"
        ],
        "build-changelog": [
            "echo building: changelog...",
            "rm -f CHANGELOG.adoc",
            "asciidoctor-reducer -o CHANGELOG.adoc doc/changelog/index.adoc",
            "asciidoctor -b docbook CHANGELOG.adoc",
            "rm -f CHANGELOG.xml"
        ],
        "build-readme": [
            "echo building: readme...",
            "rm -f README.adoc",
            "asciidoctor-reducer -o README.adoc doc/readme/index.adoc",
            "asciidoctor -b docbook README.adoc",
            "rm -f README.xml"
        ]
    }
}